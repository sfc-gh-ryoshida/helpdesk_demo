# Snowflake Postgres接続情報
POSTGRES_HOST=helpdesk-postgres.xxxxx.snowflakecomputing.com
POSTGRES_USER=helpdesk_admin
POSTGRES_PASSWORD=your_password_here

# n8n暗号化キー（32文字以上のランダム文字列）
N8N_ENCRYPTION_KEY=change-me-to-a-secure-random-key

# Snowflake MCP接続（n8nワークフローで使用）
SNOWFLAKE_MCP_CLIENT_ID=
SNOWFLAKE_MCP_CLIENT_SECRET=
