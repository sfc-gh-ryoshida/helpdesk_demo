# PostgreSQL Connection (Snowflake Postgres)
POSTGRES_HOST=your-host.postgres.snowflake.app
POSTGRES_PORT=5432
POSTGRES_DB=postgres
POSTGRES_USER=your_user
POSTGRES_PASSWORD=your_password
POSTGRES_SSL=true

# Snowflake Connection (optional - can also use snowflake-connection.toml)
SNOWFLAKE_ACCOUNT=your_account
SNOWFLAKE_USER=your_user
SNOWFLAKE_PASSWORD=your_password_or_jwt
SNOWFLAKE_WAREHOUSE=your_warehouse
SNOWFLAKE_DATABASE=HELPDESK_DB
SNOWFLAKE_SCHEMA=APP

# Slack Notification (Bot API - スレッド返信対応)
SLACK_BOT_TOKEN=xoxb-your-slack-bot-token
SLACK_DEFAULT_CHANNEL=ryoshida-demo_helpdesk-request
