    {
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT SNOWFLAKE.CORTEX.DATA_AGENT_RUN(\n  'HELPDESK_DB.APP.HELPDESK_AGENT',\n  '{\"messages\": [{\"role\": \"user\", \"content\": [{\"type\": \"text\", \"text\": \"{{ $json.body.message }}\"}]}]}'\n) AS response;"
      },
      "id": "56f1942d-6dc4-4583-b3b8-66b9ac091819",
      "name": "Call Cortex Agent",
      "type": "n8n-nodes-base.snowflake",
