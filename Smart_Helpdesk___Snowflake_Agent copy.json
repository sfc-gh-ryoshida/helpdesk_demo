        "snowflake": {
          "id": "y23VaUVNHhdumfkZ",
          "name": "Snowflake account"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "const response = $input.first().json;\n\ntry {\n  const agentResponse = JSON.parse(response.AGENT_RESPONSE || response.agent_response || '{}');\n  const messages = agentResponse.messages || [];\n  const lastMessage = messages[messages.length - 1] || {};\n  const content = lastMessage.content || '';\n  \n  let parsed = {};\n  try {\n    const jsonMatch = content.match(/\\{[\\s\\S]*\\}/);\n    if (jsonMatch) {\n      parsed = JSON.parse(jsonMatch[0]);\n    }\n  } catch (e) {\n    parsed = { raw_response: content };\n  }\n  \n  return {\n    json: {\n      reporter_name: parsed.reporter_name || null,\n      department: parsed.department || null,\n      category: parsed.category || 'OTHER',\n      priority: parsed.priority || 'MEDIUM',\n      summary: parsed.summary || 'No summary',\n      details: parsed.details || [],\n      matched_asset_id: parsed.matched_asset_id || null,\n      can_resolve: parsed.priority !== 'HIGH',\n      original_message: $('Webhook').first().json.body?.message || '',\n      user_id: $('Webhook').first().json.body?.user_id || '',\n      channel_id: $('Webhook').first().json.body?.channel_id || '',\n      raw_response: content\n    }\n  };\n} catch (e) {\n  return {\n    json: {\n      error: e.message,\n      can_resolve: false,\n      original_message: $('Webhook').first().json.body?.message || '',\n      category: 'OTHER',\n      priority: 'HIGH',\n      summary: 'Parse error - escalating'\n    }\n  };\n}"
      },
      "id": "0543556e-3cfb-46d5-b8a8-d795f52bb4bb",
      "name": "Parse Agent Response",
